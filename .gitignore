# Basic .gitignore

# Dependencies
/node_modules/
**/node_modules/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.venv/
venv/
env/
ENV/

# Build outputs
/dist/
build/
*.o
*.exe
*.out
*.class

# Logs and databases
*.log
logs/
*.sqlite
*.db

# Environment variables
.env
.env.example
.env.local
.env.*.local

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
ehthumbs_vista.db

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*~

# Large files (optional)
*.zip
*.tar.gz
*.rar

# Project specific (uncomment as needed)
# /data/
# /results/
# /models/