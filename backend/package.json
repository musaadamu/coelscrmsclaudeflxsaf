{
  "name": "coels-crms-backend",
  "version": "1.0.0",
  "description": "Backend services for COELS Records Management System",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node src/db/seed.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "worker": "ts-node src/workers/index.ts"
  },
  "dependencies": {
    "express": "^5.0.0",
    "mongoose": "^8.4.3",
    "dotenv": "^16.4.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.2",
    "speakeasy": "^2.0.0",
    "zod": "^3.23.8",
    "@coels-crms/shared": "*",
    "bullmq": "^5.8.5",
    "redis": "^4.6.13",
    "nodemailer": "^6.9.8",
    "handlebars": "^4.7.7",
    "winston": "^3.12.0",
    "winston-daily-rotate-file": "^4.7.1",
    "@aws-sdk/client-s3": "^3.535.0",
    "@aws-sdk/s3-request-presigner": "^3.535.0",
    "@aws-sdk/cloudfront-signer": "^3.535.0",
    "express-rate-limit": "^7.1.5",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "axios": "^1.6.8",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/speakeasy": "^2.0.10",
    "@types/nodemailer": "^6.4.14",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
