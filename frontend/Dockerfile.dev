FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
COPY ./shared ../shared

RUN npm install

# Copy source code
COPY src ./src
COPY index.html ./
COPY vite.config.ts ./
COPY tsconfig*.json ./

# Expose port
EXPOSE 5173

# For development: use Vite dev server
CMD ["npm", "run", "dev", "--", "--host"]
